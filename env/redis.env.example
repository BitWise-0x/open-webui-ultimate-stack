# =============================================================================
# Redis / Valkey — in-memory cache and WebSocket broker
# No required variables for basic operation.
# =============================================================================

# Note: the host running this container must have vm.overcommit_memory=1 set.
# Add to /etc/sysctl.conf:  vm.overcommit_memory = 1
# Apply without reboot:     sysctl vm.overcommit_memory=1
