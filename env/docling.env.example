# =============================================================================
# Docling Serve — heavy document extraction (alternative to Tika)
# Docs: https://github.com/docling-project/docling-serve
#
# Optional service — not included in the default stack.
# Docling excels at structured extraction of PDFs, tables, and complex layouts.
# Tika (included by default) covers most use cases; add Docling if you need
# higher-fidelity extraction of scientific papers, multi-column documents, etc.
#
# To enable: add a docling service block to docker-stack-compose.yml referencing
# this env file, and point CONTENT_EXTRACTION_ENGINE=docling in owui.env.
# =============================================================================

DOCLING_SERVE_ENABLE_UI=true
DOCLING_SERVE_ALLOW_EXTERNAL_PLUGINS=true
DOCLING_SERVE_ENABLE_REMOTE_SERVICES=true
DOCLING_SERVE_MAX_SYNC_WAIT=900
# UVICORN_WORKERS=2
