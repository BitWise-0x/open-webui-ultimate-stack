# =============================================================================
# SearXNG — private metasearch engine
# Docs: https://docs.searxng.org/
# =============================================================================

SEARXNG_DEBUG=false
SEARXNG_IMAGE_PROXY=true
SEARXNG_STATIC_USE_HASH=true
SEARXNG_UWSGI_WORKERS=4
SEARXNG_UWSGI_THREADS=4
SEARXNG_REQUEST_TIMEOUT=6.0
SEARXNG_PORT=8080
SEARXNG_HOSTNAME=searxng
SEARXNG_BIND_ADDRESS=0.0.0.0
SEARXNG_VALKEY_URL=valkey://redis:6379/3

# Generate with: openssl rand -hex 32
SEARXNG_SECRET=change_me

# Standalone (direct port access on localhost:8888):
SEARXNG_BASE_URL=http://localhost:8888/
# Swarm without Traefik (internal service URL):
# SEARXNG_BASE_URL=http://searxng:8080/
# Swarm with Traefik subpath stripping:
# SEARXNG_BASE_URL=/searxng
# Swarm with Traefik dedicated subdomain:
# SEARXNG_BASE_URL=https://searxng.your.domain.com
