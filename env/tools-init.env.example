# =============================================================================
# tools-init — Open WebUI tools/filters/functions init container
# This container runs once on deploy, pushes Python tools via the internal API,
# then exits. It bypasses Traefik OAuth using a direct container URL.
#
# Authentication: signs in with admin credentials to get a fresh token on every
# deploy — no manual API key management needed.
# Credentials must match WEBUI_ADMIN_EMAIL / WEBUI_ADMIN_PASSWORD in owui.env.
# =============================================================================

OWUI_ADMIN_EMAIL=admin@example.com
OWUI_ADMIN_PASSWORD=change_me

# Internal service URL — do not change unless you rename the openwebui service
OWUI_API_URL=http://openwebui:8080
