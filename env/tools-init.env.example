# =============================================================================
# tools-init — Open WebUI tools/filters/functions init container
# This container runs once on deploy, pushes Python tools via the internal API,
# then exits. It bypasses Traefik OAuth using a direct container URL + API key.
# =============================================================================

# Generate an API key in Open WebUI: Settings > Account > API Keys
# After first deploy: create an admin user, generate a key, redeploy tools-init.
OWUI_API_KEY=your_openwebui_api_key_here

# Internal service URL — do not change unless you rename the openwebui service
OWUI_API_URL=http://openwebui:8080
