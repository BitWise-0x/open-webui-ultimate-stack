# =============================================================================
# open-webui-ultimate-stack — top-level environment
# Used by: docker-stack-compose.yml (Swarm) and bootstrap.sh
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Stack identity ---
STACK_NAME=open-webui

# --- Traefik routing ---
# The subdomain for Open WebUI, e.g. "openwebui" → openwebui.your.domain.com
ROUTER_NAME=openwebui
ROOT_DOMAIN=your.domain.com

# --- Docker Swarm networking ---
# Overlay backend network name (created by deploy-swarm.sh)
BACKEND_NETWORK_NAME=open-webui_backend

# --- Data root (Swarm only) ---
# Base path on the Swarm nodes for bind-mounted service data.
# GlusterFS, NFS, or any shared filesystem reachable on every node.
# Example: /mnt/glusterfs/open-webui  |  /srv/data
DATA_ROOT=/mnt/data

# --- PostgreSQL placement (Swarm only) ---
# Hostname of the node where the db service should be pinned.
DB_NODE_HOSTNAME=manager

# --- Apache Tika version override ---
# Matches the image tag used in docker-compose.yml / docker-stack-compose.yml
TIKA_TAG=3.2.2.0
